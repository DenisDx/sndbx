# sndbx environment configuration
# Copy this to .env and configure for your environment

# Root directory path (set automatically by install.sh)
SNDBX_ROOT=/home/user/sndbx

# Logging level (trace, debug, info, warning, error, critical)
LOG_LEVEL=info

# Log wipe period in seconds (0 = never wipe)
LOG_WIPE_PERIOD=0

# Web UI configuration
WEBUI_PORT=30080
WEBUI_HOST=0.0.0.0

# MCP Server configuration
MCP_PORT=30081
MCP_HOST=0.0.0.0

# SSH proxy port range
SSH_PORT_MIN=30200
SSH_PORT_MAX=30210

# Default admin user
ROOT_USER=admin
ROOT_PASSWORD=admin

# MCP token authentication (comma-separated tokens)
MCP_TOKENS=test-token-123456789

# VM configuration
VM_ID=sandbox-1
VM_IMAGE=ubuntu:22.04
VM_MEMORY=2G
VM_CPUS=2
VM_DISK_MAX=20G
# Placeholder for future traffic accounting/quota (not implemented yet)
VM_NETWORK_TRAFFIC_MAX=100G

# Shared directories (host paths, guest paths configured in config.json5)
VM_SHARED_DIR=/tmp/sndbx-shared

# SSH configuration
VM_SSH_USER=root
VM_SSH_PORT_RANGE_START=30200
VM_SSH_PORT_RANGE_END=30210

# Public key used by local image sandboxes (optional)
MY_SSH_PUBLIC_KEY=

# MCP toolbox sandbox port exposure settings
MCP_TOOLBOX_BIND_HOST=127.0.0.1
MCP_TOOLBOX_FS_PORT=39011
MCP_TOOLBOX_BASH_PORT=39012
MCP_TOOLBOX_GIT_PORT=39013
