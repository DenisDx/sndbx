// sndbx main configuration (JSON5 format)
{
  version: "1.0",
  title: "sndbx minimal setup",
  instance: "${SNDBX_INSTANCE:-sndbx-dev}",
  root: "${SNDBX_ROOT}",
  
  logging: {
    level: "${LOG_LEVEL:-info}",
    // Use "local" for server local timezone, "UTC", or IANA name (e.g. "Europe/Moscow").
    "timezone": "${LOG_TIMEZONE:-local}",
    levels: {
      "core": "info",
      "webui": "info",
      "mcp": "info",
      "sandbox_manager": "info",
      "ssh": "info"
    },
    wipe_period: ${LOG_WIPE_PERIOD:-0},
  },

  webui: {
    port: ${WEBUI_PORT:-30080},
    bind: "${WEBUI_HOST:-127.0.0.1}",
    auth: {
      mode: "login",
      session_ttl: 86400,
      users: [
        {
          login: "${ROOT_USER:-admin}",
          password: "${ROOT_PASSWORD:-changeme}",
          permissions: ["all"]
        }
      ]
    }
  },

  mcp: {
    port: ${MCP_PORT:-30081},
    bind: "${MCP_HOST:-0.0.0.0}",
    auth: {
      mode: "token",
      tokens: ["${MCP_TOKENS:-test-token-123456789}"]
    },
    items: []  // reserved for future multi-backend support
  },

  sandboxes: {
    items: {
      "sandbox-1": {
        title: "Default Sandbox",
        image: "${VM_IMAGE:-default_sandbox_1}",
        memory: "${VM_MEMORY:-2G}",
        cpus: ${VM_CPUS:-2},
        disk_max: "${VM_DISK_MAX:-20G}",
        network_traffic_max: "${VM_NETWORK_TRAFFIC_MAX:-100G}",
        persistent: true,
        run_at_startup: true,
        ssh_keys: [],
        shared_directories: [
          {
            host_path: "${VM_SHARED_DIR:-/tmp/sndbx-shared}",
            guest_path: "/mnt/shared",
            permission: "rw"
          },
          {
            host_path: "${SNDBX_ROOT}/shared/default_sandbox_1/.ssh",
            guest_path: "/root/.ssh",
            mount_type: "dir",
            permission: "rw"
          },
          {
            host_path: "${SNDBX_ROOT}/shared/default_sandbox_1/shared",
            guest_path: "/root/shared",
            permission: "rw",
            host_mode: "0777"
          }
        ]
      },
      "default-sandbox-1": {
        title: "Local image sandbox test",
        image: "default_sandbox_1",
        memory: "${VM_MEMORY:-2G}",
        cpus: ${VM_CPUS:-2},
        disk_max: "${VM_DISK_MAX:-20G}",
        network_traffic_max: "${VM_NETWORK_TRAFFIC_MAX:-100G}",
        persistent: true,
        run_at_startup: false,
        ssh_keys: [
          "${MY_SSH_PUBLIC_KEY}"
        ],
        shared_directories: [
          {
            host_path: "${VM_SHARED_DIR:-/tmp/sndbx-shared}/default-sandbox-1",
            guest_path: "/mnt/shared",
            permission: "rw"
          },
          {
            host_path: "${SNDBX_ROOT}/shared/default_sandbox_1/.ssh",
            guest_path: "/root/.ssh",
            mount_type: "dir",
            permission: "rw"
          },
          {
            host_path: "${SNDBX_ROOT}/shared/default_sandbox_1/shared",
            guest_path: "/root/shared",
            permission: "rw",
            host_mode: "0777"
          }
        ]
      },
      "mcp-toolbox-1": {
        title: "MCP toolbox sandbox",
        image: "mcp_toolbox_1",
        memory: "${VM_MEMORY:-2G}",
        cpus: ${VM_CPUS:-2},
        disk_max: "${VM_DISK_MAX:-20G}",
        network_traffic_max: "${VM_NETWORK_TRAFFIC_MAX:-100G}",
        persistent: true,
        run_at_startup: false,
        ssh_keys: [
          "${MY_SSH_PUBLIC_KEY}"
        ],
        shared_directories: [
          {
            host_path: "${SNDBX_ROOT}/shared/mcp_toolbox_1/.ssh",
            guest_path: "/root/.ssh",
            mount_type: "dir",
            permission: "rw"
          },
          {
            host_path: "${SNDBX_ROOT}/shared/mcp_toolbox_1/shared",
            guest_path: "/root/shared",
            permission: "rw",
            host_mode: "0777"
          }
        ],
        // Generic host->VM published services (not limited to MCP)
        port_bindings: [
          {
            bind_host: "${MCP_TOOLBOX_BIND_HOST:-127.0.0.1}",
            vm_port: 9011,
            publish_port: ${MCP_TOOLBOX_FS_PORT:-39011}
          },
          {
            bind_host: "${MCP_TOOLBOX_BIND_HOST:-127.0.0.1}",
            vm_port: 9012,
            publish_port: ${MCP_TOOLBOX_BASH_PORT:-39012}
          },
          {
            bind_host: "${MCP_TOOLBOX_BIND_HOST:-127.0.0.1}",
            vm_port: 9013,
            publish_port: ${MCP_TOOLBOX_GIT_PORT:-39013}
          }
        ],
        // MCP bindings for sndbx-side proxy routing by envid
        mcp_bindings: [
          {
            backend_id: "filesystem",
            transport: "tcp-jsonl",
            vm_port: 9011,
            tools: ["*"],
            auth_mode: "token_passthrough",
            startup_timeout_sec: 10,
            read_timeout_sec: 30
          },
          {
            backend_id: "bash",
            transport: "tcp-jsonl",
            vm_port: 9012,
            tools: ["*"],
            auth_mode: "token_passthrough",
            startup_timeout_sec: 10,
            read_timeout_sec: 30
          },
          {
            backend_id: "git",
            transport: "tcp-jsonl",
            vm_port: 9013,
            tools: ["*"],
            auth_mode: "token_passthrough",
            startup_timeout_sec: 10,
            read_timeout_sec: 30
          }
        ]
      }
    }
  },

  envids: {
    "default-env-token": {
      sandbox: "sandbox-1",
      description: "Default environment for testing"
    },
    "mcp-toolbox-env-token": {
      sandbox: "mcp-toolbox-1",
      description: "MCP toolbox environment"
    }
  },

  users: {
    items: [
      {
        login: "testuser",
        password: "testpass",
        token: "test-token-123456789",
        envids: ["default-env-token", "mcp-toolbox-env-token"]
      }
    ]
  },

  ssh: {
    port_range: [${SSH_PORT_MIN:-30200}, ${SSH_PORT_MAX:-30210}],
    session_ttl: 3600  // 1 hour
  }
}
